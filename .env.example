# ==========================================
# Project Monolith — Environment Configuration
# ==========================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

# ==========================================
# Bot Tokens (from @BotFather on Telegram)
# ==========================================
ADMIN_BOT_TOKEN="YOUR_ADMIN_BOT_TOKEN"
AI_BOT_TOKEN="YOUR_AI_BOT_TOKEN"
CRYPTO_BOT_TOKEN="YOUR_CRYPTO_BOT_TOKEN"
GROUP_BOT_TOKEN="YOUR_GROUP_BOT_TOKEN"
SUPPORT_BOT_TOKEN="YOUR_SUPPORT_BOT_TOKEN"

# ==========================================
# Admin
# ==========================================
ADMIN_USER_ID="YOUR_TELEGRAM_USER_ID"

# ==========================================
# Webhook & Server
# ==========================================
WEBHOOK_URL="https://your-deployment.up.railway.app"
WEBHOOK_SECRET="GENERATE_A_RANDOM_32_CHAR_STRING"
PORT="8080"

# ==========================================
# Database (PostgreSQL via Supabase or similar)
# ==========================================
DATABASE_URL="postgresql+asyncpg://user:password@host:port/dbname"

# ==========================================
# Database Tuning
# ==========================================
DB_POOL_SIZE="5"

# ==========================================
# Blockchain RPCs
# ==========================================
ETH_RPC_URL="https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY"
SOLANA_RPC_URL="https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY"
ETHERSCAN_API_KEY="YOUR_ETHERSCAN_API_KEY"

# ==========================================
# AI Services
# ==========================================
GROQ_API_KEY="gsk_YOUR_GROQ_API_KEY"
SUPPORT_GROQ_API_KEY="gsk_YOUR_SUPPORT_GROQ_KEY"
SERPER_API_KEY="YOUR_SERPER_API_KEY"

# ==========================================
# Supabase (optional — for future web dashboard)
# ==========================================
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_YOUR_KEY"
SUPABASE_SECRET_KEY="sb_secret_YOUR_KEY"

# ==========================================
# Logging
# ==========================================
LOG_LEVEL="INFO"

# ==========================================
# Feature Flags
# ==========================================
ENABLE_WHALE_ALERTS="true"
ENABLE_NEW_PAIRS="true"
MAINTENANCE_MODE="false"
